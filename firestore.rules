rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function getUserData() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return isSignedIn() && getUserData().role == 'admin'; }
    function isPremium() { return isSignedIn() && getUserData().plan == 'premium'; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Global Safety Net
    match /{document=**} { allow read, write: if false; }

    // User Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) 
        && request.resource.data.keys().hasAll(['uid', 'email', 'plan', 'role', 'status', 'createdAt']) 
        && (
          (request.resource.data.email == 'markostamaki23@gmail.com' && request.resource.data.role == 'admin') ||
          (request.resource.data.role == 'user')
        )
        && request.resource.data.status == 'active';
      allow update: if (
        isOwner(userId) 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'plan', 'language', 'updatedAt'])
        && resource.data.status == 'active'
      ) || isAdmin();
      allow delete: if isAdmin();
    }
    
    // Property Rules
    match /properties/{propertyId} {
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid && isValidId(propertyId);
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // Expense Rules
    match /expenses/{expenseId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidId(expenseId);
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Maintenance Rules
    match /maintenance_tasks/{taskId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && ((resource.data.userId == request.auth.uid && isPremium()) || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidId(taskId) && isPremium();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
